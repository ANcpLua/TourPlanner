@using Blazored.Toast.Configuration
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Components.Routing
@using UI.Auth
@using UI.View.SharedComponents
@inherits LayoutComponentBase
@inject CookieAuthenticationStateProvider AuthStateProvider
@inject NavigationManager Navigation
@inject HttpClient Http

<div class="tour-planner-app">
    <BlazoredToasts Position="ToastPosition.TopRight"
                    Timeout="3"
                    IconType="IconType.FontAwesome"
                    ErrorIcon="error"
                    InfoIcon="info"
                    SuccessIcon="check"
                    WarningIcon="warning"
                    ShowProgressBar="false"
                    ShowCloseButton="true"
                    MaxToastCount="3">
        <CloseButtonContent>
            <div>
                <span class="myCloseButtonStyleClass">&times;</span>
            </div>
        </CloseButtonContent>
    </BlazoredToasts>

    <nav class="navbar navbar-expand-lg">
        <div class="container-fluid">
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav"
                    aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse justify-content-center" id="navbarNav">
                <ul class="navbar-nav">
                    <AuthorizeView>
                        <Authorized>
                            <li class="nav-item">
                                <NavLink class="nav-link" href="/" Match="NavLinkMatch.All">
                                    Tours
                                </NavLink>
                            </li>
                            <li class="nav-item">
                                <NavLink class="nav-link" href="/log/list">
                                    Tour Log
                                </NavLink>
                            </li>
                            <li class="nav-item">
                                <NavLink class="nav-link" href="/reports">
                                    Tour Report
                                </NavLink>
                            </li>
                        </Authorized>
                    </AuthorizeView>
                </ul>

                <AuthorizeView>
                    <Authorized>
                        <div class="d-flex align-items-center ms-auto gap-2">
                            <span class="navbar-text">@context.User.FindFirst(System.Security.Claims.ClaimTypes.Email)?.Value</span>
                            <button class="btn btn-outline-secondary btn-sm" @onclick="LogoutAsync">Logout</button>
                        </div>
                    </Authorized>
                </AuthorizeView>
            </div>
        </div>
    </nav>

    <main class="container-fluid">
        <AuthorizeView>
            <Authorized>
                <SearchComponent/>
            </Authorized>
        </AuthorizeView>

        @Body
    </main>
</div>

@code {
    private async Task LogoutAsync()
    {
        await Http.PostAsync("api/auth/logout", null);
        AuthStateProvider.NotifyAuthStateChanged();
        Navigation.NavigateTo("/login");
    }
}
